# App
NODE_ENV=development
CORS_ORIGIN=*
PORT=3000

# Docker Compose (PostgreSQL)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme
POSTGRES_DB=app
POSTGRES_PORT=5432

# Docker Compose (Redis)
REDIS_PORT=6379

# Docker Compose (Elasticsearch)
ELASTICSEARCH_PORT=9200
ELASTIC_PASSWORD=changeme-elastic-password

# Prisma / App DB
DATABASE_URL=postgresql://postgres:changeme@localhost:5432/app?schema=public

REDIS_HOST=localhost
REDIS_PORT=6379

CATALOG_CACHE_ENABLED=true
CATALOG_CACHE_CATEGORIES_TTL_SECONDS=900
CATALOG_CACHE_FILTERS_TTL_SECONDS=600
CATALOG_CACHE_PRODUCTS_LIST_TTL_SECONDS=60
CATALOG_CACHE_PRODUCT_DETAILS_TTL_SECONDS=180
COMMERCE_CACHE_ENABLED=true
COMMERCE_CACHE_CART_TTL_SECONDS=30
COMMERCE_CACHE_ORDERS_LIST_TTL_SECONDS=60
COMMERCE_CACHE_ORDER_DETAILS_TTL_SECONDS=90

# App (Elasticsearch)
ELASTICSEARCH_ENABLED=true
ELASTICSEARCH_NODE=http://localhost:9200
ELASTICSEARCH_USERNAME=elastic
ELASTICSEARCH_PASSWORD=changeme-elastic-password
ELASTICSEARCH_API_KEY=
ELASTICSEARCH_PRODUCTS_INDEX=products_v1

# JWT (min 16 chars)
JWT_ACCESS_SECRET=change-me-access-secret-16+
JWT_REFRESH_SECRET=change-me-refresh-secret-16+
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=30d

FRONTEND_URL=http://localhost:3001
APP_URL=http://localhost:3000

# Google OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/google/callback

# Yandex OAuth (optional)
YANDEX_CLIENT_ID=
YANDEX_CLIENT_SECRET=
YANDEX_CALLBACK_URL=http://localhost:3000/api/auth/yandex/callback

# Resend (optional in dev — emails skipped if empty)
RESEND_API_KEY=
RESEND_FROM=Auth <onboarding@resend.dev>

AUTH_REFRESH_COOKIE_NAME=refreshToken

# Checkout
CHECKOUT_CURRENCY=RUB
CHECKOUT_DELIVERY_FIXED_AMOUNT=15

# YooKassa
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
YOOKASSA_RETURN_URL=http://localhost:3001/checkout/result
YOOKASSA_WEBHOOK_SECRET=dev-yookassa-webhook-secret
